@model ADCCS_Web.Models.Target
@{
    ViewData["Title"] = "Create Target";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Target</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="TargetCode" class="form-label">Target Code</label>
                            <input asp-for="TargetCode" class="form-control" placeholder="Leave blank for auto-generate" />
                            <small class="text-muted">Leave blank to auto-generate</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TargetTypeId" class="form-label">Target Type *</label>
                            <select asp-for="TargetTypeId" class="form-select" required>
                                <option value="">-- Select Type --</option>
                                <option value="Aircraft">Aircraft</option>
                                <option value="Missile">Missile</option>
                                <option value="Drone">Drone</option>
                                <option value="Helicopter">Helicopter</option>
                            </select>
                            <span asp-validation-for="TargetTypeId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ClassificationId" class="form-label">Classification *</label>
                            <select asp-for="ClassificationId" class="form-select" required>
                                <option value="Unknown">Unknown</option>
                                <option value="Friendly">Friendly</option>
                                <option value="Hostile">Hostile</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Heading" class="form-label">Heading (degrees)</label>
                            <input asp-for="Heading" type="number" class="form-control" min="0" max="360" value="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PositionX" class="form-label">Position X</label>
                            <input asp-for="PositionX" type="number" step="0.1" class="form-control" value="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PositionY" class="form-label">Position Y</label>
                            <input asp-for="PositionY" type="number" step="0.1" class="form-control" value="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Speed" class="form-label">Speed (km/h)</label>
                            <input asp-for="Speed" type="number" class="form-control" value="500" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Altitude" class="form-label">Altitude (ft)</label>
                            <input asp-for="Altitude" type="number" class="form-control" value="10000" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Create Target
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
