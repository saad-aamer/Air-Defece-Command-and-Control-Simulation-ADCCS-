@model ADCCS_Web.Models.Target
@{
    ViewData["Title"] = "Delete Target";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body text-center">
                <i class="bi bi-trash text-danger" style="font-size: 60px;"></i>
                <h4 class="mt-3">Are you sure you want to delete this target?</h4>
                <p class="text-muted">Target: <strong>@Model.TargetCode</strong></p>

                <table class="table table-sm mt-4">
                    <tr>
                        <th>Type</th>
                        <td>@Model.TargetTypeNavigation?.Name</td>
                    </tr>
                    <tr>
                        <th>Classification</th>
                        <td>
                            <span class="badge bg-@(Model.ClassificationNavigation?.Name == "Hostile" ? "danger" : Model.ClassificationNavigation?.Name == "Friendly" ? "success" : "warning")">
                                @Model.ClassificationNavigation?.Name
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th>Detected At</th>
                        <td>@Model.DetectedAt</td>
                    </tr>
                </table>

                <div class="alert alert-warning mt-3">
                    <i class="bi bi-info-circle me-1"></i>
                    This action will mark the target as inactive. It will not be permanently deleted.
                </div>

                <form asp-action="Delete" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.TargetId" />
                    <a asp-action="Index" class="btn btn-secondary me-2">
                        <i class="bi bi-x-circle me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Delete Target
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
