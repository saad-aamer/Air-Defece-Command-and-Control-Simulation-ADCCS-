@using ADCCS_Web.Helpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Griffins Terminal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script type="module" src="https://cdn.skypack.dev/@@hotwired/turbo"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-brand">
            <img src="~/sherdilsLogo.png" alt="Sherdils Logo" style="height: 60px; width: auto; object-fit: contain; margin-bottom: 10px;" />
            <h4>SHERDILS </h4>
            <small>Air Defence Command & Control</small>
        </div>

        <div class="sidebar-menu">
            <div class="menu-header">Main Menu</div>
            <nav class="nav flex-column">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Radar" ? "active" : "")"
                   asp-controller="Radar" asp-action="Monitor">
                    <i class="bi bi-broadcast"></i> Radar Monitor
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Targets" ? "active" : "")"
                   asp-controller="Targets" asp-action="Index">
                    <i class="bi bi-crosshair"></i> Targets
                </a>
            </nav>

            @if (Context.Session.GetString("Role") == "Commander" || Context.Session.GetString("Role") == "Admin")
            {
                <div class="menu-header">Command</div>
                <nav class="nav flex-column">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Actions" ? "active" : "")"
                       asp-controller="Actions" asp-action="Index">
                        <i class="bi bi-lightning"></i> Defensive Actions
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Alerts" ? "active" : "")"
                       asp-controller="Alerts" asp-action="Index">
                        <i class="bi bi-exclamation-triangle"></i> Threat Alerts
                    </a>
                </nav>
            }

            <div class="menu-header">Reports</div>
            <nav class="nav flex-column">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   asp-controller="Reports" asp-action="Index">
                    <i class="bi bi-file-earmark-bar-graph"></i> Mission Reports
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Logs" ? "active" : "")"
                   asp-controller="Reports" asp-action="Logs">
                    <i class="bi bi-journal-text"></i> Mission Logs
                </a>
            </nav>

            @if (Context.Session.GetString("Role") == "Admin")
            {
                <div class="menu-header">Administration</div>
                <nav class="nav flex-column">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                       asp-controller="Admin" asp-action="Users">
                        <i class="bi bi-people"></i> User Management
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Configuration" ? "active" : "")"
                       asp-controller="Admin" asp-action="Configuration">
                        <i class="bi bi-gear"></i> System Config
                    </a>
                </nav>
            }
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <div>
                <h5 class="mb-0">@ViewData["Title"]</h5>
            </div>

            <div class="d-flex align-items-center gap-3">
                <!-- Alert Bell -->
                <div class="alert-badge">
                    <a asp-controller="Alerts" asp-action="Index" class="btn btn-light btn-sm rounded-circle">
                        <i class="bi bi-bell"></i>
                    </a>
                    <span class="badge bg-danger rounded-pill" id="alertCount">0</span>
                </div>

                <!-- User Dropdown -->
                <div class="dropdown user-dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" data-turbo="false">
                        <div class="user-avatar me-2">
                            @(Context.Session.GetString("FullName")?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <div class="d-none d-md-block text-start">
                            <div class="fw-semibold">@Context.Session.GetString("FullName")</div>
                            <small class="text-muted">@Context.Session.GetString("Role")</small>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><h6 class="dropdown-header">@Context.Session.GetString("Username")</h6></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout" data-turbo="false">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="page-content">
            <!-- Success/Error Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>

    <script>
        // Update alert count periodically
        function updateAlertCount() {
            let alertCountElem = document.getElementById('alertCount');
            if (!alertCountElem) return;
            
            fetch('/Alerts/GetCount')
                .then(response => response.json())
                .then(data => {
                    if (document.getElementById('alertCount')) {
                        document.getElementById('alertCount').textContent = data.count;
                    }
                })
                .catch(err => console.log('Error fetching alerts:', err));
        }

        updateAlertCount();
        if (window.alertInterval) clearInterval(window.alertInterval);
        window.alertInterval = setInterval(updateAlertCount, 30000); // Update every 30 seconds
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
