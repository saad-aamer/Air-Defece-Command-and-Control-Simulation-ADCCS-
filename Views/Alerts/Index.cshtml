@model List<ADCCS_Web.Models.ThreatAlert>
@{
    ViewData["Title"] = "Threat Alerts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Threat Alerts</h4>
        <small class="text-muted">Monitor and manage threat alerts</small>
    </div>
    <form asp-action="AcknowledgeAll" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-success" onclick="return confirm('Acknowledge all alerts?')">
            <i class="bi bi-check-all me-2"></i>Acknowledge All
        </button>
    </form>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select name="acknowledged" class="form-select">
                    <option value="">All</option>
                    <option value="false" selected="@(ViewBag.Acknowledged == false)">Active Only</option>
                    <option value="true" selected="@(ViewBag.Acknowledged == true)">Acknowledged</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Alert Level</label>
                <select name="alertLevel" class="form-select">
                    <option value="">All Levels</option>
                    @{
                        var alertLevels = ViewBag.AlertLevels as List<ADCCS_Web.Models.AlertLevel> ?? new List<ADCCS_Web.Models.AlertLevel>();
                    }
                    @foreach (var lvl in alertLevels)
                    {
                        <option value="@lvl.Name" selected="@(ViewBag.AlertLevel == lvl.Name)">@lvl.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-search me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Alerts List -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="list-group list-group-flush">
            @if (Model.Any())
            {
                @foreach (var alert in Model)
                {
                    <div class="list-group-item @(alert.IsAcknowledged == 0 ? "list-group-item-warning" : "")">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-@(alert.AlertLevelNavigation?.Name == "Critical" ? "danger" : alert.AlertLevelNavigation?.Name == "High" ? "warning text-dark" : alert.AlertLevelNavigation?.Name == "Medium" ? "info" : "secondary") me-3" style="min-width: 70px;">
                                    @alert.AlertLevelNavigation?.Name
                                </span>
                                <div>
                                    <h6 class="mb-1">@alert.Message</h6>
                                    <small class="text-muted">
                                        Target: <a asp-controller="Targets" asp-action="Details" asp-route-id="@alert.TargetId">@alert.Target?.TargetCode</a>
                                        | Created: @alert.CreatedAt
                                    </small>
                                </div>
                            </div>
                            <div>
                                @if (alert.IsAcknowledged == 0)
                                {
                                    <form asp-action="Acknowledge" asp-route-id="@alert.AlertId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="bi bi-check me-1"></i> Acknowledge
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i> Acknowledged
                                    </span>
                                    <small class="d-block text-muted mt-1">
                                        by @alert.AcknowledgedByNavigation?.Username
                                    </small>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="list-group-item text-center py-5">
                    <i class="bi bi-check-circle text-success" style="font-size: 50px;"></i>
                    <h5 class="mt-3">No Alerts Found</h5>
                    <p class="text-muted">All clear! No threat alerts match your criteria.</p>
                </div>
            }
        </div>
    </div>
</div>
